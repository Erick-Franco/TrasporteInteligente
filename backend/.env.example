# Ejemplo de variables de entorno para el backend
# Copia este archivo a `.env` y rellena los valores reales (NO subir `.env` al repo)

PORT=3000

# Connection string de Postgres (Supabase)
# Ejemplo: postgresql://user:pass@host:port/dbname
DATABASE_URL="postgresql://postgres:TU_PASS@aws-1-us-east-2.pooler.supabase.com:6543/postgres"

# Alternativa: variables individuales (si no usas DATABASE_URL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=transporte_db
DB_USER=postgres
DB_PASSWORD=changeme

NODE_ENV=development

CORS_ORIGIN=*  # ajustar en producción
